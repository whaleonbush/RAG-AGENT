# API
HOST=0.0.0.0
PORT=8000

# Storage (project files, metadata, chroma)
DATA_DIR=./storage

# Embeddings: fastembed (default) | ollama
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Ollama (on-prem LLM + optional embeddings)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# RAG
CHUNK_SIZE=800
CHUNK_OVERLAP=120
RETRIEVAL_TOP_K=6
