# API
HOST=0.0.0.0
PORT=8000

# Storage (project files, metadata, chroma)
DATA_DIR=./storage

# Embeddings: fastembed (default) | ollama
EMBEDDING_PROVIDER=fastembed
# 한국어 문서라면 다국어 모델 권장 (영어 전용 bge-small보다 정확):
#   intfloat/multilingual-e5-small  (가볍고 빠름, CPU 권장)
#   BAAI/bge-m3                     (정확하지만 무겁고 느림)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# 0=CPU 코어 수 자동. 임베딩 스레드 수.
EMBEDDING_THREADS=0
EMBEDDING_BATCH_SIZE=32

# Ollama (on-prem LLM + optional embeddings)
OLLAMA_BASE_URL=http://localhost:11434
# CPU 환경에서는 작은 모델이 훨씬 빠름:
#   llama3.2:3b / qwen2.5:3b-instruct / qwen2.5:1.5b-instruct
OLLAMA_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text
# 모델을 메모리에 유지(재로딩 방지). CPU에서 체감 속도에 큰 영향.
OLLAMA_KEEP_ALIVE=30m
# 컨텍스트 창 토큰 수(작을수록 빠름).
OLLAMA_NUM_CTX=4096
# 답변 최대 토큰(작을수록 빠름).
OLLAMA_NUM_PREDICT=512

# RAG
CHUNK_SIZE=800
CHUNK_OVERLAP=120
# CPU에서는 4 정도로 줄이면 컨텍스트가 짧아져 답변이 빨라짐.
RETRIEVAL_TOP_K=6
